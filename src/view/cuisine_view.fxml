<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="550.0" spacing="0.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CuisineController">
   <children>
      
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="‍ BRIGADE CUISINE" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <HBox spacing="10.0" alignment="CENTER_LEFT">
                     <Label fx:id="lblStatut" text="Initialisation..." textFill="#3498db" style="-fx-font-weight: bold;" />
                     <Label fx:id="lblClock" text="--:--" textFill="#bdc3c7" />
                  </HBox>
               </children>
            </VBox>
            
            <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="DÉCONNEXION">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </padding>
            </Button>
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8f9fa;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="containerCommandes" spacing="20.0" style="-fx-padding: 25;">
               </VBox>
         </content>
      </ScrollPane>
      
   </children>
</VBox>

