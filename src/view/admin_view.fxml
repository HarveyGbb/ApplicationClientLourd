<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminController">
   
   <left>
      <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 25 15 25 15; -fx-pref-width: 200;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 18;" text="DRAGON D'OR" textFill="#f1c40f" />
            <Separator opacity="0.2" />
            
            <Button onAction="#afficherCommandesView" prefWidth="170.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-weight: bold;" text=" COMMANDES" />
            
            <Button onAction="#afficherStatsView" prefWidth="170.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-weight: bold;" text=" STATISTIQUES" />
            
            <Button onAction="#handleExport" prefWidth="170.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-weight: bold;" text="EXPORT CSV" />
            
            <VBox VBox.vgrow="ALWAYS" /> <Button onAction="#handleLogout" prefWidth="170.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text=" DÉCONNEXION" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0" style="-fx-background-color: #f5f6fa; -fx-padding: 30;">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label fx:id="lblTitrePage" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2f3640;" text="Tableau de Bord" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblClock" textFill="#7f8c8d" />
               </children>
            </HBox>
            
            <Label fx:id="lblStatut" text="Initialisation..." textFill="#27ae60" />
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="mainContent" spacing="15.0" />
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
